        "path": "/api/calculate",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "savings": 10,
          "buyPrices": [5, 5, 10],
          "sellPrices": [15, 10, 35],
          "companyNames": ["Initech"]
        },
