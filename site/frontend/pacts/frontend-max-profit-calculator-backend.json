{
  "consumer": {
    "name": "frontend"
  },
  "provider": {
    "name": "max-profit-calculator-backend"
  },
  "interactions": [
    {
      "description": "a request to calculate max profit - returns calculated values",
      "request": {
        "method": "POST",
        "path": "/api/calculate",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "savings": 10,
          "buyPrices": [5, 5, 10],
          "sellPrices": [15, 10, 35],
          "companyNames": ["Acme Corp", "Globex Inc", "Initech"]
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "pact:matcher:type": "type",
          "value": {
            "maxProfit": 20,
            "indices": [0, 1],
            "savingsUsed": 10,
            "remainingSavings": 0,
            "companyNames": ["Acme Corp", "Globex Inc"]
          }
        }
      }
    },
    {
      "description": "a request with invalid savings",
      "request": {
        "method": "POST",
        "path": "/api/calculate",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "savings": -10,
          "buyPrices": [5, 5, 10],
          "sellPrices": [15, 10, 35]
        }
      },
      "response": {
        "status": 400,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "pact:matcher:type": "type",
          "value": {
            "message": "Invalid input: Savings must be at least 1"
          }
        }
      }
    },
    {
      "description": "a health check request",
      "request": {
        "method": "GET",
        "path": "/api/health"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "text/plain"
        },
        "body": "OK"
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "3.0.0"
    }
  }
}
