<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <suppress checks=".*" files="**/Test*.java"/>
    <suppress checks=".*" files="**/*Test.java"/>
    <suppress checks="Javadoc" files="**/*.java"/>
    <suppress checks="DesignForExtension" files="**/*.java"/>
    <suppress checks="HiddenField" files="**/*.java"/>
    <suppress checks="FinalParameters" files="**/*.java"/>
    <suppress checks="JavadocPackage" files="**/*.java"/>
    <suppress checks="LineLength" files="**/*.java"/>
    <suppress checks="OperatorWrap" files="**/Stock.java"/>
    <suppress checks="RegexpSingleline" files="**/Stock.java"/>
    <suppress checks="UnusedImports" files="**/*.java"/>
    <suppress checks="NewlineAtEndOfFile" files="**/*.properties"/>
</suppressions>
